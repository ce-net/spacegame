# spacegame at spa.ce-net.com — installed by deploy.sh (the __CE_API_TOKEN__ placeholder is replaced with
# the relay's local CE node API token at install time, so the secret is NOT committed to the repo).
#
# Why a dedicated block: the *.ce-net.com app-subdomain regex routes to ce-serve, which serves
# content-addressed BUNDLES; spacegame is published as per-file app storage on the hub (/apps/spa). An
# exact server_name beats the regex, so this host serves straight from the hub's per-file store, plus the
# same-origin /ce mesh bridge the WASM client needs to reach the live galaxy node.
server {
    listen 80;
    listen [::]:80;
    server_name spa.ce-net.com;

    # Same-origin mesh bridge: window.__ceNode -> this box's CE node. Token injected server-side; the
    # browser never holds it. SSE-friendly (no buffering, long read timeout) for /mesh/messages/stream.
    location /ce/ {
        proxy_pass http://127.0.0.1:8844/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header Authorization "Bearer __CE_API_TOKEN__";
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
        chunked_transfer_encoding off;
    }

    # The client bundle: index.html, boot.js, galaxy-peer.js, galaxy/gateways.json, pkg/*.
    location / {
        proxy_pass http://127.0.0.1:8970/apps/spa/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}
